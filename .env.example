APP_NAME="OC2 Local Job Search"
DATABASE_URL="sqlite:///./oc2.db"
OLLAMA_URL="http://localhost:11434"
OLLAMA_MODEL="qwen2.5:3b"
SCHEDULER_ENABLED=true
LOG_LEVEL="INFO"
LOG_FILE="logs/oc2.log"

# Use either FIRECRAWL_API_KEY for each local session, or the encrypted pair below.
FIRECRAWL_API_KEY=""
# FIRECRAWL_API_KEY_ENCRYPTED=""
# FIRECRAWL_SECRET_KEY=""
FIRECRAWL_SEARCH_LIMIT=8
FIRECRAWL_COUNTRY="IN"
FIRECRAWL_LOCATION="India"
FIRECRAWL_LOCATION_TERMS="India,Bengaluru,Bangalore,Hyderabad,Pune,Chennai,Mumbai,Gurugram,Gurgaon,Noida"
FIRECRAWL_TIMEOUT_MS=60000
SEARCH_BATCH_SIZE=45
SEARCH_ALLOW_SAMPLE_FALLBACK=false

JOB_REPORT_TO_EMAIL="2001siddi@gmail.com"
JOB_REPORT_AFTER_SEARCH=true
JOB_REPORT_ON_SHUTDOWN=true
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USERNAME="2001siddi@gmail.com"
SMTP_PASSWORD=""
SMTP_FROM_EMAIL="2001siddi@gmail.com"
SMTP_STARTTLS=true
